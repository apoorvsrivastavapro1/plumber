{
    "name": "nest-boilerplate",
    "version": "0.0.1",
    "description": "",
    "author": "Pradeep Singh",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "start": "nest start",
        "start:dev": "NODE_ENV=development nest start --watch",
        "start:stage": "NODE_ENV=staging node dist/main",
        "start:prod": "NODE_ENV=production node dist/main",
        "start:debug": "nest start --debug --watch",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "prepare": "husky install",
        "migrate:generate": "dotenv -e .env.${NODE_ENV} -- npx typeorm-ts-node-commonjs migration:generate -d src/database/data-source.ts",
        "migrate:up": "dotenv -e .env.${NODE_ENV} -- npx typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
        "migrate:down": "dotenv -e .env.${NODE_ENV} -- npx typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
        "sonar": "node sonar-project.js"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.1.18",
        "@nestjs/platform-express": "^11.1.18",
        "@nestjs/swagger": "^11.2.7",
        "@nestjs/typeorm": "^11.0.0",
        "axios": "^1.4.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.0",
        "dotenv": "^16.3.1",
        "dotenv-cli": "^7.4.2",
        "eslint-plugin-unused-imports": "^4.1.4",
        "ioredis": "^5.3.2",
        "ms": "^2.1.3",
        "nest-winston": "^1.10.2",
        "pg": "^8.11.2",
        "reflect-metadata": "^0.1.13",
        "rxjs": "^7.8.1",
        "sonarqube-scanner": "^3.5.0",
        "typeorm": "^0.3.28",
        "uuid": "^14.0.0",
        "winston": "^3.8.2",
        "winston-daily-rotate-file": "^4.7.1"
    },
    "devDependencies": {
        "@commitlint/cli": "^18.4.3",
        "@commitlint/config-conventional": "^18.4.3",
        "@nestjs/cli": "^11.0.19",
        "@nestjs/schematics": "^11.0.10",
        "@nestjs/testing": "^11.1.18",
        "@types/express": "^4.17.17",
        "@types/jest": "^29.5.2",
        "@types/ms": "^0.7.31",
        "@types/node": "^20.3.1",
        "@types/supertest": "^2.0.12",
        "@typescript-eslint/eslint-plugin": "^7.1.1",
        "@typescript-eslint/parser": "^7.1.1",
        "eslint": "^8.42.0",
        "eslint-config-prettier": "^8.8.0",
        "eslint-plugin-prettier": "^4.2.1",
        "husky": "^8.0.0",
        "jest": "^29.5.0",
        "lint-staged": "^15.2.0",
        "prettier": "^2.8.8",
        "source-map-support": "^0.5.21",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.0",
        "ts-loader": "^9.4.3",
        "ts-node": "^10.9.1",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.1.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
